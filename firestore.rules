rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Funciones básicas
    function isSignedIn() {
      return request.auth != null;
    }

    // REGLA DE EMERGENCIA PARA RECURSOS Y ANALÍTICA
    // Permite lectura y escritura a cualquier usuario logueado
    match /resources/{id} {
      allow read, write: if isSignedIn();
    }

    match /ai_analytics/{id} {
      allow read, write: if isSignedIn();
    }

    // Reglas para perfiles de usuario
    match /userProfiles/{userId} {
      allow read, write: if isSignedIn();
    }

    // Regla genérica para el resto del curso (mantenemos la estructura anterior simplificada)
    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
      
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }
    
    match /enrollments/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /studentTopicProgress/{id} {
      allow read, write: if isSignedIn();
    }

    match /users/{userId}/aiChatMessages/{id} {
      allow read, write: if request.auth.uid == userId;
    }
  }
}
