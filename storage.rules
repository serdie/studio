rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /resources/{allPaths=**} {
      // Permitir lectura a cualquier usuario autenticado
      allow read: if request.auth != null;
      // Permitir escritura solo a profesores (basado en metadatos o simplemente autenticados para el prototipo)
      allow write: if request.auth != null;
    }
  }
}
